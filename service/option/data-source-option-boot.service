[Unit]
Description=Data Source Option - run on boot if last run > 24h ago
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=kat
WorkingDirectory=/ndata/trade/data-source/data_source
ExecStart=/ndata/trade/data-source/data_source/service/option/data-source-option-run.sh --boot
TimeoutStartSec=3600

[Install]
WantedBy=multi-user.target
