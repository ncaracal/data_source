[Unit]
Description=Data Source btceth - download & aggregate BTC/ETH spot trade data
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=kat
WorkingDirectory=/ndata/trade/data-source/data_source
EnvironmentFile=/ndata/trade/data-source/data_source/.env
ExecStart=/ndata/trade/data-source/data_source/service/btceth/data-source-btceth-run.sh
TimeoutStartSec=72000

[Install]
WantedBy=multi-user.target
